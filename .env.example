# --- External Postgres (Supabase) ---
# Format: postgresql://user:pass@host:port/dbname
DATABASE_URL=
# Note: For Supabase, the URI must start with postgresql:// and will be converted to postgresql+asyncpg:// internally.

# --- Local Postgres (Optional, for local dev only) ---
POSTGRES_USER=pmri_india
POSTGRES_PASSWORD=pmri_india_secret
POSTGRES_DB=pmri_india

# --- Auth ---
JWT_SECRET=pmri_india_jwt_secret_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# --- Market Data ---
# Options: "demo" | "real" (real requires MARKET_API_KEY)
MARKET_PROVIDER=demo
MARKET_API_KEY=

# --- App ---
DEMO_MODE=true
LOG_LEVEL=INFO

# --- Tier Limits (INR) ---
RETAIL_MAX_NOTIONAL=1000000         # ₹10 Lakh
INST_BASIC_MAX_NOTIONAL=10000000    # ₹1 Crore
INST_PREMIUM_MAX_NOTIONAL=50000000  # ₹5 Crore

# --- Policy Config ---
MIN_PREMIUM_INR=500
INTRADAY_CUTOFF_IST=15:30

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8001

# --- CORS ---
CORS_ORIGINS=http://localhost:3001
